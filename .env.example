# Optional: enables Claude-powered extraction/summarization in the LangGraph workflow.
# Without this, the workflow falls back to heuristic (regex/keyword) extraction so the demo still runs.
ANTHROPIC_API_KEY=

# MCP server transport (stdio is the default for Claude Code / Desktop)
MCP_TRANSPORT=stdio

# FastAPI host/port
HOST=0.0.0.0
PORT=8000
